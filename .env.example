APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./trading.db
LOG_DIR=logs

# Broker backend
# `paper` = Alpaca paper account
# `mock` = local CSV-backed broker for testing without Alpaca credentials
BROKER_MODE=paper

# Paper-safe defaults
TRADING_ENABLED=false
AUTO_TRADE_ENABLED=false
LIVE_TRADING_ENABLED=false
LIVE_TRADING_ACK=
ALLOW_EXTENDED_HOURS=false

# Alpaca paper account credentials
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_CRYPTO_LOCATION=us

# Discord notifications
DISCORD_NOTIFICATIONS_ENABLED=false
DISCORD_WEBHOOK_URL=
DISCORD_NOTIFY_DRY_RUNS=false
DISCORD_NOTIFY_REJECTIONS=true
DISCORD_NOTIFY_ERRORS=true
DISCORD_NOTIFY_START_STOP=true
DISCORD_NOTIFY_SCAN_SUMMARY=false
DISCORD_TIMEZONE=America/Indiana/Indianapolis

# Auto-trader single-instance guard
AUTO_TRADER_LOCK_PATH=logs/auto_trader.lock

# Asset-class controls
ENABLED_ASSET_CLASSES=["equity","etf","crypto"]
CRYPTO_ONLY_MODE=false
EQUITY_TRADING_ENABLED=true
ETF_TRADING_ENABLED=true
CRYPTO_TRADING_ENABLED=true
OPTION_TRADING_ENABLED=false

# Universe controls
UNIVERSE_SCAN_ENABLED=true
UNIVERSE_REFRESH_MINUTES=60
SCANNER_LIMIT_PER_ASSET_CLASS=8

# Symbols and strategy
DEFAULT_SYMBOLS=["AAPL","MSFT","NVDA","AMZN","META","GOOGL","SPY","QQQ","BTC/USD","ETH/USD"]
CRYPTO_SYMBOLS=["BTC/USD","ETH/USD","SOL/USD","AVAX/USD","DOGE/USD","LINK/USD","LTC/USD"]
DEFAULT_TIMEFRAME=1D
ACTIVE_STRATEGY=equity_momentum_breakout
WATCHLISTS={}
INCLUDED_SYMBOLS=[]
EXCLUDED_SYMBOLS=[]

# Scan cadence
SCAN_INTERVAL_SECONDS=300
SCAN_INTERVAL_SECONDS_BY_ASSET_CLASS={"equity":300,"etf":300,"crypto":300}

# Risk and exposure limits
MAX_RISK_PER_TRADE=0.01
MAX_DAILY_LOSS=2000
MAX_DAILY_LOSS_PCT=0.02
MAX_DRAWDOWN_PCT=0.10
MAX_POSITIONS=3
MAX_POSITIONS_TOTAL=3
MAX_POSITIONS_PER_ASSET_CLASS={"equity":3,"etf":3,"crypto":2,"option":1}
MAX_TOTAL_EXPOSURE=50000
MAX_POSITION_NOTIONAL=10000
MAX_NOTIONAL_PER_POSITION=10000
POSITION_NOTIONAL_BUFFER_PCT=0.995
ENTRY_TRANCHES=3
ENTRY_TRANCHE_WEIGHTS=0.4,0.3,0.3
SCALE_IN_MODE=confirmation
MIN_BARS_BETWEEN_TRANCHES=1
MINUTES_BETWEEN_TRANCHES=5
ADD_ON_FAVORABLE_MOVE_PCT=0.5
ALLOW_AVERAGE_DOWN=false
MAX_NOTIONAL_PER_ASSET_CLASS={"equity":20000,"etf":20000,"crypto":10000,"option":2500}
MAX_CORRELATED_POSITIONS=2

# Market quality filters
MAX_SPREAD_PCT=0.02
MIN_DOLLAR_VOLUME=100000
MIN_PRICE=5
MIN_AVG_VOLUME=1000
DATA_STALE_AFTER_SECONDS=900

# Trading behavior
SHORT_SELLING_ENABLED=false
COOLDOWN_SECONDS_PER_SYMBOL=900
COOLDOWN_SECONDS_PER_STRATEGY=300
TAKE_PROFIT_PCT=0.05
STOP_LOSS_ATR_MULTIPLIER=2.0
KILL_SWITCH_ENABLED=false

# Optional per-strategy switches
STRATEGY_SWITCHES={}

# ML scoring + registry
ML_ENABLED=false
ML_MODEL_TYPE=logistic_regression
ML_MIN_SCORE_THRESHOLD=0.55
ML_MIN_TRAIN_ROWS=50
ML_RETRAIN_ENABLED=false
ML_PROMOTION_MIN_AUC=0.55
ML_PROMOTION_MIN_PRECISION=0.50
ML_PROMOTION_MIN_WINRATE_LIFT=0.00
MODEL_DIR=models
ML_CURRENT_MODEL_PATH=models/current_model.joblib
ML_CANDIDATE_MODEL_PATH=models/candidate_model.joblib
ML_REGISTRY_PATH=models/registry.json

# News feature pipeline
NEWS_FEATURES_ENABLED=false
NEWS_RSS_ENABLED=false
NEWS_LLM_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-nano
NEWS_MAX_HEADLINES_PER_TICKER=8
NEWS_LOOKBACK_HOURS=24
