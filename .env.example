# Application and storage
APP_ENV=development
LOG_LEVEL=INFO
# SQLite is fine for local development. For persistent paper operations, prefer Postgres.
DATABASE_URL=sqlite:///./trading.db
# Example Postgres URL: DATABASE_URL=postgresql+psycopg://money:change-me@127.0.0.1:5432/money
LOG_DIR=logs

# Admin API protection
# Leave blank only if you do not need protected /config, /diagnostics/*, or /admin/* routes locally.
API_ADMIN_TOKEN=

# Broker connection
BROKER_MODE=paper
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_CRYPTO_LOCATION=us

# Safety switches
TRADING_ENABLED=false
AUTO_TRADE_ENABLED=false
LIVE_TRADING_ENABLED=false
LIVE_TRADING_ACK=
ALLOW_EXTENDED_HOURS=false

# Discord notifications (Discord is the only supported alert channel)
DISCORD_NOTIFICATIONS_ENABLED=false
DISCORD_WEBHOOK_URL=
DISCORD_NOTIFY_DRY_RUNS=false
DISCORD_NOTIFY_REJECTIONS=true
DISCORD_NOTIFY_ERRORS=true
DISCORD_NOTIFY_START_STOP=true
DISCORD_NOTIFY_SCAN_SUMMARY=false
DISCORD_NOTIFY_HOLDS_MANUAL=true
DISCORD_NOTIFY_CRYPTO=true
DISCORD_TIMEZONE=America/Indiana/Indianapolis
DISCORD_DEDUPE_TTL_SECONDS=45

# Single-process runtime safeguards
AUTO_TRADER_LOCK_PATH=logs/auto_trader.lock
BROKER_ORDER_STATUS_CACHE_PATH=logs/broker_order_status_memory.json
BROKER_ORDER_STATUS_SUPPRESS_STARTUP_REPLAY=true
BROKER_ORDER_STATUS_IGNORE_TERMINAL_OLDER_THAN_MINUTES=180

# Asset-class controls
ENABLED_ASSET_CLASSES=["equity","etf","crypto"]
CRYPTO_ONLY_MODE=false
EQUITY_TRADING_ENABLED=true
ETF_TRADING_ENABLED=true
CRYPTO_TRADING_ENABLED=true
OPTION_TRADING_ENABLED=false

# Universe controls
UNIVERSE_SCAN_ENABLED=true
UNIVERSE_REFRESH_MINUTES=60
SCAN_UNIVERSE_MODE=full
SCANNER_LIMIT_PER_ASSET_CLASS=20
UNIVERSE_PREFILTER_LIMIT_BY_ASSET_CLASS={"equity":80,"etf":50,"crypto":80}
FINAL_EVALUATION_LIMIT_BY_ASSET_CLASS={"equity":20,"etf":15,"crypto":20}

# Symbols and strategy selection
DEFAULT_SYMBOLS=["AAPL","MSFT","NVDA","AMZN","META","GOOGL","SPY","QQQ","BTC/USD","ETH/USD"]
CRYPTO_SYMBOLS=["BTC/USD","ETH/USD","SOL/USD","AVAX/USD","DOGE/USD","LINK/USD","LTC/USD"]
MAJOR_EQUITY_SYMBOLS=["AAPL","MSFT","NVDA","AMZN","GOOGL","META","TSLA","SPY","QQQ","IWM"]
MAJOR_CRYPTO_SYMBOLS=["BTC/USD","ETH/USD","SOL/USD","AVAX/USD"]
DEFAULT_TIMEFRAME=1D
ENTRY_TIMEFRAME_BY_ASSET_CLASS={"equity":"15Min","etf":"15Min","crypto":"15Min"}
REGIME_TIMEFRAME_BY_ASSET_CLASS={"equity":"1D","etf":"1D","crypto":"4H"}
SCANNER_TIMEFRAME_BY_ASSET_CLASS={"equity":"15Min","etf":"15Min","crypto":"15Min"}
LOOKBACK_BARS_BY_ASSET_CLASS={"equity":120,"etf":120,"crypto":160}
ACTIVE_STRATEGY=equity_momentum_breakout
ACTIVE_STRATEGY_BY_ASSET_CLASS={"equity":"equity_momentum_breakout","etf":"equity_momentum_breakout","crypto":"crypto_momentum_trend"}
WATCHLISTS={}
INCLUDED_SYMBOLS=[]
EXCLUDED_SYMBOLS=[]

# Scan cadence
SCAN_INTERVAL_SECONDS=60
SCAN_INTERVAL_SECONDS_BY_ASSET_CLASS={"equity":180,"etf":180,"crypto":60}

# Risk and exposure limits
MAX_RISK_PER_TRADE=0.01
RISK_PER_TRADE_PCT=0.01
MAX_DAILY_LOSS=2000
MAX_DAILY_LOSS_PCT=0.02
MAX_DRAWDOWN_PCT=0.10
MAX_POSITIONS=3
MAX_POSITIONS_TOTAL=3
MAX_CONCURRENT_POSITIONS=3
MAX_POSITIONS_PER_ASSET_CLASS={"equity":3,"etf":3,"crypto":2,"option":1}
MAX_TOTAL_EXPOSURE=50000
MAX_POSITION_NOTIONAL=10000
MAX_NOTIONAL_PER_POSITION=10000
POSITION_NOTIONAL_BUFFER_PCT=0.995
DUST_POSITION_MAX_NOTIONAL=1.00
DUST_POSITION_MAX_QTY_BY_ASSET_CLASS={"crypto":0.000001,"equity":0.0,"etf":0.0,"option":0.0}
MAX_SYMBOL_ALLOCATION_PCT=0.10
MAX_ASSET_CLASS_ALLOCATION_PCT={"equity":0.35,"etf":0.35,"crypto":0.15,"option":0.05}
MAX_NOTIONAL_PER_ASSET_CLASS={"equity":20000,"etf":20000,"crypto":10000,"option":2500}
MAX_CORRELATED_POSITIONS=2

# Entry and scaling controls
ENTRY_TRANCHES=3
ENTRY_TRANCHE_WEIGHTS=0.4,0.3,0.3
SCALE_IN_MODE=confirmation
MIN_BARS_BETWEEN_TRANCHES=1
MINUTES_BETWEEN_TRANCHES=5
ADD_ON_FAVORABLE_MOVE_PCT=0.5
ALLOW_AVERAGE_DOWN=false

# Market quality filters
MAX_SPREAD_PCT=0.02
MIN_DOLLAR_VOLUME=100000
MIN_PRICE=5
MIN_AVG_VOLUME=1000
DATA_STALE_AFTER_SECONDS=900
QUOTE_STALE_AFTER_SECONDS=30
PREFER_PRIMARY_CRYPTO_QUOTES=true

# Trading behavior
SHORT_SELLING_ENABLED=false
REQUIRE_EASY_TO_BORROW_FOR_SHORTS=true
REQUIRE_MARGINABLE_FOR_SHORTS=true
COOLDOWN_SECONDS_PER_SYMBOL=900
COOLDOWN_SECONDS_PER_STRATEGY=300
SYMBOL_REENTRY_COOLDOWN_MINUTES=0
TAKE_PROFIT_PCT=0.05
STOP_LOSS_ATR_MULTIPLIER=2.0
ENABLE_PARTIAL_EXITS=true
PARTIAL_TAKE_PROFIT_LEVELS=1.0,2.0
PARTIAL_TAKE_PROFIT_FRACTIONS=0.5,1.0
BREAK_EVEN_AFTER_R_MULTIPLE=1.0
TRAILING_STOP_MODE=atr
TRAILING_STOP_ATR_MULTIPLE=2.5
TIME_STOP_BARS=20
KILL_SWITCH_ENABLED=false
STRATEGY_SWITCHES={}

# ML scoring and model registry
# ML remains optional and must not bypass hard risk controls.
ML_ENABLED=false
ENTRY_MODEL_ENABLED=true
EXIT_MODEL_ENABLED=false
ML_MODEL_TYPE=logistic_regression
ML_MIN_SCORE_THRESHOLD=0.55
ML_EXIT_MIN_SCORE=0.55
ML_MIN_TRAIN_ROWS=50
ML_RETRAIN_ENABLED=false
ML_ENTRY_MIN_AUC=0.55
ML_ENTRY_MIN_PRECISION=0.50
ML_PROMOTION_MIN_AUC=0.55
ML_PROMOTION_MIN_PRECISION=0.50
ML_PROMOTION_MIN_WINRATE_LIFT=0.00
ML_PROMOTION_MIN_PROFIT_FACTOR=1.05
ML_PROMOTION_MAX_DRAWDOWN=0.20
ML_PROMOTION_MIN_EXPECTANCY=0.00
WALK_FORWARD_ENABLED=true
MODEL_DIR=models
ML_CURRENT_MODEL_PATH=models/current_model.joblib
ML_CANDIDATE_MODEL_PATH=models/candidate_model.joblib
ML_ENTRY_CURRENT_MODEL_PATH=models/current_model.joblib
ML_ENTRY_CANDIDATE_MODEL_PATH=models/candidate_model.joblib
ML_EXIT_CURRENT_MODEL_PATH=models/current_exit_model.joblib
ML_EXIT_CANDIDATE_MODEL_PATH=models/candidate_exit_model.joblib
ML_REGISTRY_PATH=models/registry.json

# News features
# News is feature-only and never places orders directly.
NEWS_FEATURES_ENABLED=false
NEWS_RSS_ENABLED=false
NEWS_LLM_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-nano
NEWS_MAX_HEADLINES_PER_TICKER=8
NEWS_LOOKBACK_HOURS=24
