# Core runtime
APP_ENV=production
LOG_LEVEL=INFO
BROKER_MODE=paper
TRADING_ENABLED=false
AUTO_TRADE_ENABLED=true
ALLOW_EXTENDED_HOURS=false
ENTRY_TIMEFRAME_BY_ASSET_CLASS={"equity":"15Min","etf":"15Min","crypto":"15Min"}
REGIME_TIMEFRAME_BY_ASSET_CLASS={"equity":"1D","etf":"1D","crypto":"4H"}
SCANNER_TIMEFRAME_BY_ASSET_CLASS={"equity":"15Min","etf":"15Min","crypto":"15Min"}
LOOKBACK_BARS_BY_ASSET_CLASS={"equity":120,"etf":120,"crypto":160}
UNIVERSE_PREFILTER_LIMIT_BY_ASSET_CLASS={"equity":50,"etf":50,"crypto":50}
FINAL_EVALUATION_LIMIT_BY_ASSET_CLASS={"equity":15,"etf":15,"crypto":15}
SCAN_INTERVAL_SECONDS=60
SCAN_INTERVAL_SECONDS_BY_ASSET_CLASS={"equity":300,"etf":300,"crypto":120}

# Notifications
DISCORD_NOTIFICATIONS_ENABLED=false
DISCORD_WEBHOOK_URL=
DISCORD_NOTIFY_DRY_RUNS=false
DISCORD_NOTIFY_REJECTIONS=true
DISCORD_NOTIFY_ERRORS=true
DISCORD_NOTIFY_START_STOP=true
DISCORD_NOTIFY_SCAN_SUMMARY=false

# Logging + storage
LOG_DIR=logs
AUTO_TRADER_LOCK_PATH=logs/auto_trader.lock
MODEL_DIR=models
ML_CURRENT_MODEL_PATH=models/current_model.joblib
ML_CANDIDATE_MODEL_PATH=models/candidate_model.joblib
ML_REGISTRY_PATH=models/registry.json

# ML
ML_ENABLED=false
ML_MODEL_TYPE=logistic_regression
ML_MIN_SCORE_THRESHOLD=0.55
ML_MIN_TRAIN_ROWS=50
ML_RETRAIN_ENABLED=false
ML_PROMOTION_MIN_AUC=0.55
ML_PROMOTION_MIN_PRECISION=0.50
ML_PROMOTION_MIN_WINRATE_LIFT=0.00

# News features
NEWS_FEATURES_ENABLED=false
NEWS_RSS_ENABLED=false
NEWS_LLM_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-nano
NEWS_MAX_HEADLINES_PER_TICKER=8
NEWS_LOOKBACK_HOURS=24
