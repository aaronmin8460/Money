# Money Phase 5 deployment env example for Ubuntu EC2/systemd
#
# Minimum variables for the basic API:
# - DATABASE_URL
# - BROKER_MODE=paper
# - ALPACA_API_KEY
# - ALPACA_SECRET_KEY
# - API_ADMIN_TOKEN
#
# Optional additions:
# - Discord notifications: set DISCORD_NOTIFICATIONS_ENABLED=true and DISCORD_WEBHOOK_URL
# - Aggressive paper mode: set TRADING_PROFILE=aggressive and AGGRESSIVE_MODE_ENABLED=true
# - News RSS only: set NEWS_FEATURES_ENABLED=true, NEWS_RSS_ENABLED=true, and the source toggles you want
# - News RSS + OpenAI LLM: also set NEWS_LLM_ENABLED=true and OPENAI_API_KEY
# - FastAPI rate limiting: set RATE_LIMIT_ENABLED=true
# - Nightly ML retrain: set ML_RETRAIN_ENABLED=true
# - Free market data: default composite routes Yahoo Finance for equities/ETFs/options and CoinGecko for crypto

# Core runtime
APP_ENV=production
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./data/trading.db
LOG_DIR=logs
MODEL_DIR=models
API_ADMIN_TOKEN=

# Broker connection
BROKER_MODE=paper
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_CRYPTO_LOCATION=us

# Market data providers
MARKET_DATA_PROVIDER_DEFAULT=composite
EQUITY_DATA_PROVIDER=yfinance
ETF_DATA_PROVIDER=yfinance
CRYPTO_DATA_PROVIDER=coingecko
OPTION_DATA_PROVIDER=yfinance
MARKET_DATA_FALLBACK_PROVIDERS=alpaca
PROVIDER_RATE_LIMITS_PER_MINUTE={"alpaca":120,"yfinance":30,"coingecko":25,"tradier":60}
SNAPSHOT_CACHE_TTL_SECONDS=5
INTRADAY_BARS_CACHE_TTL_SECONDS=30
DAILY_BARS_CACHE_TTL_SECONDS=300
OPTION_CHAIN_CACHE_TTL_SECONDS=60
MARKET_DATA_MAX_RETRIES=2
MARKET_DATA_BACKOFF_BASE_SECONDS=1
MARKET_DATA_BACKOFF_MAX_SECONDS=30
COINGECKO_API_KEY=
TRADIER_API_TOKEN=

# Phase 5 safe first boot: conservative paper dry-run API with the in-process trader disabled.
# Keep these values for the first systemd boot until health, /auto/status, and logs look clean.
TRADING_ENABLED=false
AUTO_TRADE_ENABLED=false
LIVE_TRADING_ENABLED=false
LIVE_TRADING_ACK=
ALLOW_EXTENDED_HOURS=false
TRADING_PROFILE=conservative
AGGRESSIVE_MODE_ENABLED=false
AGGRESSIVE_PROFILE_VERSION=v1

# Phase 5 continuous paper order-submission mode:
# After dry-run verification, flip only these two values:
# TRADING_ENABLED=true
# AUTO_TRADE_ENABLED=true

# Aggressive paper profile example:
# Keep live trading disabled and opt into this only after conservative paper mode is verified.
# TRADING_PROFILE=aggressive
# AGGRESSIVE_MODE_ENABLED=true
# AGGRESSIVE_SHORTS_ENABLED=true
# AGGRESSIVE_EXTENDED_HOURS_ENABLED=true
# TRADING_ENABLED=true
# AUTO_TRADE_ENABLED=true

# Single-process runtime safeguards
AUTO_TRADER_LOCK_PATH=logs/auto_trader.lock
BROKER_ORDER_STATUS_CACHE_PATH=logs/broker_order_status_memory.json
BROKER_ORDER_STATUS_SUPPRESS_STARTUP_REPLAY=true
BROKER_ORDER_STATUS_IGNORE_TERMINAL_OLDER_THAN_MINUTES=180
HALT_ON_CONSECUTIVE_LOSSES=true
MAX_CONSECUTIVE_LOSING_EXITS=3
HALT_ON_RECONCILE_MISMATCH=true
HALT_ON_STARTUP_SYNC_FAILURE=true

# Trading cadence and symbols
DEFAULT_SYMBOLS=["AAPL","MSFT","NVDA","SPY","QQQ","BTC/USD","ETH/USD"]
CRYPTO_SYMBOLS=["BTC/USD","ETH/USD","SOL/USD","AVAX/USD"]
SCAN_INTERVAL_SECONDS=60
SCAN_INTERVAL_SECONDS_BY_ASSET_CLASS={"equity":300,"etf":300,"crypto":120}
ENTRY_TIMEFRAME_BY_ASSET_CLASS={"equity":"15Min","etf":"15Min","crypto":"15Min"}
REGIME_TIMEFRAME_BY_ASSET_CLASS={"equity":"1D","etf":"1D","crypto":"4H"}
SCANNER_TIMEFRAME_BY_ASSET_CLASS={"equity":"15Min","etf":"15Min","crypto":"15Min"}
LOOKBACK_BARS_BY_ASSET_CLASS={"equity":90,"etf":90,"crypto":120,"option":60}
UNIVERSE_PREFILTER_LIMIT_BY_ASSET_CLASS={"equity":25,"etf":20,"crypto":20,"option":10}
FINAL_EVALUATION_LIMIT_BY_ASSET_CLASS={"equity":10,"etf":8,"crypto":8,"option":5}
AGGRESSIVE_SCAN_INTERVAL_SECONDS_BY_ASSET_CLASS={"equity":60,"etf":60,"crypto":30}
AGGRESSIVE_UNIVERSE_PREFILTER_LIMIT_BY_ASSET_CLASS={"equity":90,"etf":75,"crypto":80}
AGGRESSIVE_FINAL_EVALUATION_LIMIT_BY_ASSET_CLASS={"equity":24,"etf":20,"crypto":24}

# Notifications
# Minimum for Discord notifications:
# - DISCORD_NOTIFICATIONS_ENABLED=true
# - DISCORD_WEBHOOK_URL=<real webhook>
DISCORD_NOTIFICATIONS_ENABLED=false
DISCORD_WEBHOOK_URL=
DISCORD_NOTIFY_DRY_RUNS=false
DISCORD_NOTIFY_REJECTIONS=true
DISCORD_NOTIFY_ERRORS=true
DISCORD_NOTIFY_START_STOP=true
DISCORD_NOTIFY_SCAN_SUMMARY=false

# Risk posture
MAX_RISK_PER_TRADE=0.01
RISK_PER_TRADE_PCT=0.01
MAX_DAILY_LOSS=2000
MAX_DAILY_LOSS_PCT=0.02
MAX_DRAWDOWN_PCT=0.10
MAX_POSITIONS=3
MAX_POSITIONS_TOTAL=3
MAX_CONCURRENT_POSITIONS=3
MAX_POSITION_NOTIONAL=10000
MAX_NOTIONAL_PER_POSITION=10000
POSITION_NOTIONAL_BUFFER_PCT=0.995
MAX_SYMBOL_ALLOCATION_PCT=0.10
MAX_ASSET_CLASS_ALLOCATION_PCT={"equity":0.35,"etf":0.35,"crypto":0.15,"option":0.05}
MAX_NOTIONAL_PER_ASSET_CLASS={"equity":20000,"etf":20000,"crypto":10000,"option":2500}
SHORT_SELLING_ENABLED=false
ENTRY_TRANCHES=3
ENTRY_TRANCHE_WEIGHTS=0.4,0.3,0.3
SCALE_IN_MODE=confirmation
MIN_BARS_BETWEEN_TRANCHES=1
MINUTES_BETWEEN_TRANCHES=5
ADD_ON_FAVORABLE_MOVE_PCT=0.5
AGGRESSIVE_ENTRY_THRESHOLD_ADJUSTMENT=-0.08
AGGRESSIVE_MAX_POSITIONS=5
AGGRESSIVE_MAX_POSITIONS_PER_ASSET_CLASS={"equity":4,"etf":4,"crypto":3}
AGGRESSIVE_RISK_PER_TRADE_PCT=0.0125
AGGRESSIVE_MAX_SYMBOL_ALLOCATION_PCT=0.12
AGGRESSIVE_NEWS_CATALYST_WEIGHT=0.35
AGGRESSIVE_SHORTS_ENABLED=false
AGGRESSIVE_EXTENDED_HOURS_ENABLED=false
ALLOW_AVERAGE_DOWN=false
TAKE_PROFIT_PCT=0.05
STOP_LOSS_ATR_MULTIPLIER=2.0
ENABLE_PARTIAL_EXITS=true
PARTIAL_TAKE_PROFIT_LEVELS=1.0,2.0
PARTIAL_TAKE_PROFIT_FRACTIONS=0.5,1.0
BREAK_EVEN_AFTER_R_MULTIPLE=1.0
TRAILING_STOP_MODE=atr
TRAILING_STOP_ATR_MULTIPLE=2.5
TIME_STOP_BARS=20

# Optional news feature refresh
# RSS-only minimum:
# - NEWS_FEATURES_ENABLED=true
# - NEWS_RSS_ENABLED=true
# - configure at least one RSS URL source and/or SEC_RSS_ENABLED=true
# RSS + OpenAI LLM minimum:
# - NEWS_FEATURES_ENABLED=true
# - NEWS_RSS_ENABLED=true
# - NEWS_LLM_ENABLED=true
# - OPENAI_API_KEY=<real key>
NEWS_FEATURES_ENABLED=false
NEWS_RSS_ENABLED=false
NEWS_LLM_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-nano
NEWS_MAX_HEADLINES_PER_TICKER=8
NEWS_LOOKBACK_HOURS=24
NEWS_SOURCE_IDS=
REUTERS_RSS_URLS=[]
MARKETWATCH_RSS_URLS=["https://feeds.marketwatch.com/marketwatch/topstories/"]
# Benzinga is disabled by default. Supply a verified endpoint before enabling it.
BENZINGA_RSS_ENABLED=false
BENZINGA_RSS_URLS=[]
SEC_RSS_ENABLED=false
SEC_RSS_URLS=["https://www.sec.gov/cgi-bin/browse-edgar?action=getcurrent&output=atom&owner=include&count=40"]
SEC_USER_AGENT=MoneyBot/1.0 (paper-safe research; contact unset)
SEC_COMPANY_TICKERS_URL=https://www.sec.gov/files/company_tickers.json
SEC_COMPANY_TICKERS_CACHE_PATH=cache/sec_company_tickers.json
SEC_COMPANY_TICKERS_CACHE_TTL_HOURS=24
NEWS_FETCH_TIMEOUT_SECONDS=10
NEWS_FETCH_RETRY_COUNT=2
NEWS_FETCH_BACKOFF_SECONDS=1.5
NEWS_DEDUPE_WINDOW_MINUTES=45
NEWS_SOURCE_WEIGHTS={}
NEWS_ENABLE_SOURCE_DIVERSITY_FEATURES=true

# Optional source URL overrides. MarketWatch may redirect; the fetcher follows redirects.
# REUTERS_RSS_URLS=["https://example.com/reuters-feed.xml"]
# MARKETWATCH_RSS_URLS=["https://feeds.marketwatch.com/marketwatch/topstories/"]

# Benzinga RSS example, only with a verified endpoint:
# BENZINGA_RSS_ENABLED=true
# BENZINGA_RSS_URLS=["https://example.com/verified-benzinga-feed.xml"]

# SEC RSS example:
# SEC_RSS_ENABLED=true
# SEC_RSS_URLS=["https://www.sec.gov/cgi-bin/browse-edgar?action=getcurrent&output=atom&owner=include&count=40"]
# SEC_USER_AGENT=MoneyBot/1.0 (paper-safe research; contact=ops@example.com)

# Rate limit example:
RATE_LIMIT_ENABLED=false
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_STORAGE_URI=memory://
RATE_LIMIT_HEADERS_ENABLED=true
RATE_LIMIT_SCANNER=12/minute
RATE_LIMIT_ADMIN=10/minute
RATE_LIMIT_MARKET=60/minute
RATE_LIMIT_SIGNALS=30/minute
RATE_LIMIT_HEALTH_EXEMPT=true
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_DEFAULT=60/minute
# RATE_LIMIT_SCANNER=6/minute
# RATE_LIMIT_ADMIN=5/minute

# Optional ML scoring and nightly retrain
# Nightly retrain timer can stay installed even when ML_RETRAIN_ENABLED=false; it will exit 0 cleanly.
# Keep ML disabled until you intentionally want the trained candidate/current models to influence scoring.
ML_ENABLED=false
ENTRY_MODEL_ENABLED=true
EXIT_MODEL_ENABLED=false
ML_MODEL_TYPE=logistic_regression
ML_MIN_SCORE_THRESHOLD=0.55
ML_EXIT_MIN_SCORE=0.55
ML_MIN_TRAIN_ROWS=50
ML_RETRAIN_ENABLED=false
ML_ENTRY_MIN_AUC=0.55
ML_ENTRY_MIN_PRECISION=0.50
ML_PROMOTION_MIN_AUC=0.55
ML_PROMOTION_MIN_PRECISION=0.50
ML_PROMOTION_MIN_WINRATE_LIFT=0.00
ML_PROMOTION_MIN_PROFIT_FACTOR=1.05
ML_PROMOTION_MAX_DRAWDOWN=0.20
ML_PROMOTION_MIN_EXPECTANCY=0.00
WALK_FORWARD_ENABLED=true
ML_CURRENT_MODEL_PATH=models/current_model.joblib
ML_CANDIDATE_MODEL_PATH=models/candidate_model.joblib
ML_ENTRY_CURRENT_MODEL_PATH=models/current_model.joblib
ML_ENTRY_CANDIDATE_MODEL_PATH=models/candidate_model.joblib
ML_EXIT_CURRENT_MODEL_PATH=models/current_exit_model.joblib
ML_EXIT_CANDIDATE_MODEL_PATH=models/candidate_exit_model.joblib
ML_REGISTRY_PATH=models/registry.json
